# Symphony Workshop Kit — environment
# Copy to .env and fill in. Source it (`set -a; . ./.env; set +a`) in both the
# Phase-1 (planning) shell and the Phase-2 (engine) shell.

# Linear API key (Settings → API → Personal API keys). Used by the linear skill,
# convert-tasks-to-linear, and the engine's Linear MCP. REQUIRED for both phases.
LINEAR_API_KEY=lin_api_xxxxxxxxxxxxxxxxxxxx

# Anthropic API key — used by the `claude` CLI that the OpenSymphony engine
# launches per ticket in Phase 2. REQUIRED for Phase 2.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# --- Reference values you'll set during setup (not consumed automatically) ---

# Linear project slugId (from the project URL: linear.app/<team>/project/<name>-<SLUG>).
# Put this into engine/WORKFLOW.md -> tracker.project_slug, and pass to
# convert-tasks-to-linear --project-slug.
SYMPHONY_LINEAR_PROJECT_SLUG=your-project-xxxxxxxxxxxx

# Git URL of your TARGET repo (seeded from target-repo-template/, pushed to GitHub).
# Put this into engine/WORKFLOW.md -> hooks.after_create clone command.
SYMPHONY_TARGET_REPO_URL=git@github.com:you/symphony.git
